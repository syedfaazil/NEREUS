#!/bin/bash
# Test GPU CUDA compute via the vnode workaround (no ngpus request)
#PBS -N gpu_cuda_test
#PBS -q workq
#PBS -l select=1:ncpus=1:mem=4gb:vnode=node02
#PBS -l walltime=00:10:00
#PBS -j oe
#PBS -o gpu_cuda_test.log

set -euo pipefail

echo "========================================"
echo "GPU CUDA Compute Test"
echo "Host:       $(hostname)"
echo "Job ID:     ${PBS_JOBID:-local}"
echo "Start:      $(date)"
echo "========================================"

# --- Check nvidia-smi ---
echo ""
echo "--- nvidia-smi ---"
nvidia-smi

# --- Use micromamba Python if available ---
MAMBA_ROOT="${HOME}/micromamba"
PYTHON="${MAMBA_ROOT}/envs/planktonai_v2/bin/python3"

if [ ! -f "${PYTHON}" ]; then
    PYTHON=$(which python3 2>/dev/null || echo "")
fi

if [ -z "${PYTHON}" ]; then
    echo "FAIL: No python3 found"
    exit 1
fi

echo ""
echo "Using: ${PYTHON} ($(${PYTHON} --version 2>&1))"

# --- Full CUDA test ---
echo ""
echo "--- PyTorch CUDA Test ---"
${PYTHON} -c "
import torch
print(f'PyTorch:        {torch.__version__}')
print(f'CUDA available: {torch.cuda.is_available()}')
print(f'CUDA version:   {torch.version.cuda}')
print(f'Device count:   {torch.cuda.device_count()}')

if not torch.cuda.is_available():
    print('FAIL: CUDA not available')
    exit(1)

print(f'GPU name:       {torch.cuda.get_device_name(0)}')
props = torch.cuda.get_device_properties(0)
print(f'GPU memory:     {props.total_mem / 1e9:.1f} GB')

# Allocate and compute on GPU
print()
print('Running matmul benchmark...')
x = torch.randn(4096, 4096, device='cuda')
torch.cuda.synchronize()

import time
start = time.time()
for _ in range(10):
    y = x @ x
torch.cuda.synchronize()
elapsed = time.time() - start

print(f'10x [4096x4096] matmul: {elapsed:.3f}s ({elapsed/10*1000:.1f}ms each)')
print(f'Peak GPU memory used:   {torch.cuda.max_memory_allocated()/1e9:.2f} GB')
print()
print('SUCCESS: GPU compute is fully working!')
"

echo ""
echo "========================================"
echo "Test finished at $(date)"
echo "========================================"
